---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
---

<BaseLayout
  title="About - J. Brandon Johnson"
  description="Full-stack developer, solutions architect, AI engineer, designer, husband, and father of two. 15+ years turning ambitious ideas into shipped systems."
  canonical="/about"
>
  <section class="page-hero">
    <div class="container split">
      <div>
        <span class="eyebrow"><span></span>About me</span>
        <h1>Hi, I'm <em>Brandon</em>.<br />I build things that think.</h1>
        <p>
          Full-stack developer and solutions architect with 15+ years of shipping
          ambitious software. These days I'm focused on agentic workflows,
          frontier models, and automation that rewires how teams operate.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/contact">Start a conversation</a>
          <a class="button ghost" href="/john-brandon-johnson-resume.pdf">View resume</a>
        </div>
      </div>
      <img class="portrait-card" src="/images/family.png" alt="Brandon with his family" />
    </div>
  </section>
  <section class="section">
    <div class="container">
      <SectionHeading eyebrow="Profile" title="Engineer, designer, operator, dad" />
      <div class="card-grid three">
        {[
          "AI-forward engineer",
          "Full-stack builder",
          "Designer at heart",
          "Solutions architect",
          "Husband",
          "Dad x 2",
        ].map((title) => (
          <article class="glass-card"><h3>{title}</h3><p>Pragmatic craft, long-term thinking, and systems that work in the real world.</p></article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
