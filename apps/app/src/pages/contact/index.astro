---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { site } from "@/data/site";
---

<BaseLayout
  title="Contact J. Brandon Johnson"
  description="Get in touch with Brandon Johnson about AI agent development, full stack engineering, automation consulting, or collaboration opportunities."
  canonical="/contact"
>
  <section class="section page-top">
    <div class="container">
      <SectionHeading
        eyebrow="Let's connect"
        title="Get in touch"
        description="Have a question or want to build something together? Drop a note and I'll get back to you."
      />
      <div class="contact-grid">
        <aside class="contact-list">
          <a class="glass-card" href={`mailto:${site.email}`}><span>Email</span><strong>{site.email}</strong></a>
          <div class="glass-card"><span>Location</span><strong>Orange County, CA</strong></div>
          <div class="socials">{site.socials.map((link) => <a href={link.href}>{link.label}</a>)}</div>
        </aside>
        <form class="contact-form" method="post" action={`mailto:${site.email}`} enctype="text/plain">
          <label>Name<input name="name" autocomplete="name" required /></label>
          <label>Email<input name="email" type="email" autocomplete="email" required /></label>
          <label>Message<textarea name="message" rows="7" required></textarea></label>
          <button class="button primary" type="submit">Send message</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
