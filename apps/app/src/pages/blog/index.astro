---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
  title="Blog - J. Brandon Johnson"
  description="Field notes on AI systems, agentic workflows, automation, and modern web platforms."
  canonical="/blog"
>
  <section class="section page-top">
    <div class="container">
      <SectionHeading
        eyebrow="Blog"
        title="Field notes from practical systems work"
        description="Short essays on AI systems, automation, web platforms, and operating with leverage."
      />
      <div class="card-grid two">
        {posts.map((post) => (
          <article class="post-card">
            {post.data.image && <img src={post.data.image} alt="" loading="lazy" />}
            <div>
              <time datetime={post.data.publishDate.toISOString()}>{post.data.publishDate.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}</time>
              <h2><a href={`/blog/${post.data.slug ?? post.id.replace(/\.mdx?$/, "")}/`}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
              <ul>{post.data.tags.map((tag) => <li>{tag}</li>)}</ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
