---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { aiAgents, projects, skills, technologies, testimonials, workExperience } from "@/data/site";
---

<BaseLayout
  title="J. Brandon Johnson - Software Engineering, Supercharged"
  description="Brandon Johnson is a software engineer building AI-assisted software, agentic workflows, and practical operating systems for modern teams."
>
  <section class="hero original-hero" id="home">
    <div class="cosmic-grid"></div>
    <div class="container hero-content centered">
      <div class="intro-video-shell" data-video-shell>
        <button class="avatar-button" type="button" data-hello-trigger aria-label="Play Brandon's hello video">
          <img src="/images/avatar.jpg" alt="Brandon Johnson" width="180" height="180" />
          <span class="avatar-hover"></span>
        </button>
        <button class="play-orb" type="button" data-hello-trigger aria-label="Play Brandon's hello video">▶</button>
        <div class="hello-video-popover" data-hello-popover aria-live="polite" hidden>
          <div class="video-pulse" aria-hidden="true"></div>
          <video data-hello-video class="hello-video" src="/video/brandon-hello-video.mp4" poster="/images/avatar.jpg" playsinline></video>
          <button class="video-close" type="button" data-hello-close aria-label="Close hello video">×</button>
          <button class="video-mute" type="button" data-hello-mute aria-label="Mute or unmute hello video">Sound</button>
        </div>
      </div>

      <h1>
        Software Engineering,<br />
        <em>Supercharged</em>
      </h1>
      <p>
        Hi! I'm Brandon, a 5x Software Engineer powered by the latest LLMs and
        agentic workflows. I also manage an army of AI agents that collaborate,
        learn, and act on data 24x7x365.
      </p>
      <div class="hero-actions split-actions">
        <a class="button primary" href="/john-brandon-johnson-resume.pdf">View Resume</a>
        <a class="button ghost" href="/cover-letter.md">View Cover Letter</a>
        <a class="button simple" href="/contact"><span>Contact me</span><span aria-hidden="true">→</span></a>
      </div>
      <div class="dashboard-frame">
        <div class="dashboard-glow"></div>
        <div class="dashboard-inner">
          <img src="/images/dashboard.png" alt="AI agent dashboard interface" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <section class="logo-strip" aria-label="Technology experience">
    <div class="container tech-intro">
      <h2>Accelerating results with the latest tech</h2>
      <p>My software has been having an impact on clients for over twenty years — and it just keeps getting better.</p>
    </div>
    <div class="logo-track">
      {[...technologies, ...technologies].map((logo) => (
        <img src={logo.src} alt={logo.title} loading="lazy" />
      ))}
    </div>
  </section>

  <section id="skills" class="section skills-section">
    <div class="container">
      <SectionHeading
        eyebrow="Skills"
        title="Versatile tech professional"
        description="From front-end engineering to full-stack development, data engineering, AI, and product management — I bring a comprehensive technical perspective to every project."
      />
      <div class="skills-grid">
        {skills.map((skill, index) => (
          <article class:list={["skill-card", index < 4 ? "top-row" : "bottom-row"]}>
            <div class="skill-shine"></div>
            <div class="skill-icon">{skill.icon}</div>
            <h3>{skill.title}</h3>
            <p>{skill.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="experience" class="section alt">
    <div class="container">
      <SectionHeading
        eyebrow="Track record"
        title="Work experience"
        description="Over 15 years of experience in software development and technical leadership."
      />
      <div class="timeline carousel-like">
        {workExperience.map((item) => (
          <article class="work-card">
            <img src={item.image} alt="" loading="lazy" />
            <div>
              <span>{item.period}</span>
              <h3>{item.role}</h3>
              <strong>{item.company}</strong>
              <p>{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="ai-agents" class="section agents-section">
    <div class="container">
      <SectionHeading
        eyebrow="AI Agents"
        title="Pioneering AI agent development with the Eliza framework"
        description="Expert in building sophisticated AI agents that automate complex tasks — from data processing to full system automation."
      />
      <div class="agent-grid">
        {aiAgents.map((agent, index) => (
          <article class:list={["agent-card", `agent-${index + 1}`]}>
            <div class="agent-visual" aria-hidden="true"><span>{agent.accent}</span><i></i><i></i><i></i></div>
            <h3>{agent.title}</h3>
            <p>{agent.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="projects" class="section projects-section">
    <div class="container">
      <SectionHeading
        eyebrow="Selected work"
        title="Featured projects"
        description="A showcase of enterprise-scale applications and platforms I've architected and delivered."
      />
      <div class="card-grid three">
        {projects.map((project) => (
          <article class="project-card">
            <img src={project.image} alt="" loading="lazy" />
            <div>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <ul>{project.tags.map((tag) => <li>{tag}</li>)}</ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="testimonials" class="section testimonials">
    <div class="container">
      <SectionHeading
        eyebrow="Collaborators"
        title="Loved by people across the universe"
        description="With boundless enthusiasm and contagious optimism, I bring transformative energy to every project. Passion for innovation and problem-solving creates an environment where challenges become opportunities."
      />
      <div class="card-grid two">
        {testimonials.map((testimonial) => (
          <figure class="testimonial-card">
            <div>
              <img src={testimonial.src} alt="" loading="lazy" />
              <figcaption>
                <strong>{testimonial.name}</strong>
                <span>{testimonial.designation}</span>
              </figcaption>
            </div>
            <blockquote>"{testimonial.quote}"</blockquote>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="section contact-cta" id="contact-cta">
    <div class="container cta-panel">
      <span class="eyebrow"><span></span>Contact</span>
      <h2>Ready to connect?</h2>
      <p>Contact me today to discuss your next project and learn how I can support your team.</p>
      <div class="cta-actions">
        <a class="button primary" href="/contact">Contact Me →</a>
        <a class="button ghost" href="#projects">View My Work</a>
      </div>
    </div>
  </section>
</BaseLayout>
