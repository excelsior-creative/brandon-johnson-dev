---
import { site } from "@/data/site";
---

<header class="site-header">
  <div class="container nav-shell">
    <a class="brand" href="/" aria-label="BrandonJohnson.dev home">
      <img src="/images/avatar.png" alt="" width="40" height="40" />
      <span>{site.brand}</span>
    </a>
    <nav class="desktop-nav" aria-label="Main navigation">
      {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="nav-actions">
      <button class="theme-toggle" type="button" aria-label="Toggle dark mode" title="Theme">☾</button>
      <a class="nav-cta" href="/contact">Contact</a>
      <button class="menu-button" type="button" data-menu-trigger aria-expanded="false" aria-controls="mobile-menu">
        Menu
      </button>
    </div>
  </div>
  <nav id="mobile-menu" class="mobile-nav" data-menu data-open="false" aria-label="Mobile navigation">
    {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
    <a href="/blog">Writing</a>
    <a href="/contact">Contact</a>
  </nav>
</header>
