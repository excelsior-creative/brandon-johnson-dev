---
import { site } from "@/data/site";
---

<footer class="footer">
  <div class="container footer-grid">
    <section>
      <div class="footer-brand">
        <img src="/images/avatar.png" alt="" width="40" height="40" />
        <strong>J. Brandon Johnson</strong>
      </div>
      <p>
        Building the future. Automating everything. AI-first software engineer,
        technical leader, and creator.
      </p>
    </section>
    <section>
      <h2>Navigate</h2>
      {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="/about">About</a>
    </section>
    <section>
      <h2>More</h2>
      <a href="/blog">Writing</a>
      <a href="/contact">Contact</a>
      <a href="/john-brandon-johnson-resume.pdf">Resume</a>
      <a href="/cover-letter.md">Cover Letter</a>
    </section>
    <section>
      <h2>Find me</h2>
      <div class="socials">
        {site.socials.map((link) => <a href={link.href} rel="noreferrer noopener" target="_blank">{link.label}</a>)}
      </div>
    </section>
  </div>
  <div class="footer-wordmark" aria-hidden="true">BRANDON</div>
  <div class="container footer-bottom">
    <span>© 2026 Brandon Johnson. All rights reserved.</span>
    <span>v.2 / cosmic</span>
  </div>
</footer>
