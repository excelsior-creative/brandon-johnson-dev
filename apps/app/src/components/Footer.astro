---
import { site } from "@/data/site";
---

<footer class="footer">
  <div class="container footer-grid">
    <section>
      <div class="footer-brand">
        <img src="/images/avatar.png" alt="" width="40" height="40" />
        <strong>Brandon Johnson</strong>
      </div>
      <p>
        Software engineer, AI automation enthusiast, and full-stack builder.
        Turning ideas into shipped systems since 2007.
      </p>
      <div class="socials">
        {site.socials.map((link) => <a href={link.href} rel="noreferrer noopener" target="_blank">{link.label}</a>)}
      </div>
    </section>
    <section>
      <h2>Navigate</h2>
      {site.nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </section>
    <section>
      <h2>Elsewhere</h2>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
    </section>
  </div>
  <div class="container footer-bottom">
    <span>Copyright Brandon Johnson 2026. All rights reserved.</span>
    <span>v.3 / astro static</span>
  </div>
  <div class="footer-wordmark" aria-hidden="true">BRANDON</div>
</footer>
